{
  "name": "test-analysis-agent",
  "displayName": "test-analysis-agent",
  "description": "Automated test failure root cause analysis for VS Code",
  "version": "0.1.0",
  "publisher": "logautopsy-dev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Alpharius99/LogAutopsy.git"
  },
  "homepage": "https://github.com/Alpharius99/LogAutopsy",
  "bugs": {
    "url": "https://github.com/Alpharius99/LogAutopsy/issues"
  },
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:testAnalysisAgent.loadTestArtifacts",
    "onCommand:testAnalysisAgent.loadLogOnly",
    "onCommand:testAnalysisAgent.runPhase1Analysis",
    "onCommand:testAnalysisAgent.runRootCauseAnalysis",
    "onCommand:testAnalysisAgent.createGitLabIssues",
    "onView:testAnalysisAgent.controls",
    "onView:testAnalysisAgent.sidebar"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "testAnalysisAgent.loadTestArtifacts",
        "title": "Load Full Input",
        "category": "Test Analysis Agent"
      },
      {
        "command": "testAnalysisAgent.loadLogOnly",
        "title": "Load Log Only",
        "category": "Test Analysis Agent"
      },
      {
        "command": "testAnalysisAgent.runPhase1Analysis",
        "title": "Run Phase 1 Analysis",
        "category": "Test Analysis Agent"
      },
      {
        "command": "testAnalysisAgent.runRootCauseAnalysis",
        "title": "Run Root Cause Analysis",
        "category": "Test Analysis Agent"
      },
      {
        "command": "testAnalysisAgent.createGitLabIssues",
        "title": "Create GitLab Issues",
        "category": "Test Analysis Agent"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "testAnalysisAgent-container",
          "title": "Test Analysis",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "testAnalysisAgent-container": [
        {
          "id": "testAnalysisAgent.controls",
          "name": "Controls",
          "type": "webview"
        },
        {
          "id": "testAnalysisAgent.sidebar",
          "name": "Analysis Results"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "testAnalysisAgent.sidebar",
        "when": "true",
        "contents": "No analysis results yet.\n[Load Full Input](command:testAnalysisAgent.loadTestArtifacts)\n[Load Log Only](command:testAnalysisAgent.loadLogOnly)\n\nRun the deterministic pipeline first.\n[Run Phase 1 Analysis](command:testAnalysisAgent.runPhase1Analysis)\n\nThen run the AI workflow.\n[Run Root Cause Analysis](command:testAnalysisAgent.runRootCauseAnalysis)\n\nCreate issues after reviewing the results.\n[Create GitLab Issues](command:testAnalysisAgent.createGitLabIssues)"
      }
    ],
    "configuration": {
      "title": "Test Analysis Agent",
      "properties": {
        "testAnalysisAgent.gitlab.baseUrl": {
          "type": "string",
          "default": "",
          "description": "GitLab base URL, for example https://gitlab.example.com"
        },
        "testAnalysisAgent.gitlab.projectId": {
          "type": "string",
          "default": "",
          "description": "GitLab project ID or URL-encoded path"
        },
        "testAnalysisAgent.gitlab.token": {
          "type": "string",
          "default": "",
          "markdownDescription": "GitLab personal access token used for issue creation."
        },
        "testAnalysisAgent.continue.vendor": {
          "type": "string",
          "default": "",
          "description": "Optional VS Code language model vendor selector."
        },
        "testAnalysisAgent.continue.family": {
          "type": "string",
          "default": "",
          "description": "Optional VS Code language model family selector."
        },
        "testAnalysisAgent.continue.modelId": {
          "type": "string",
          "default": "",
          "description": "Optional VS Code language model id selector."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && node esbuild.js",
    "compile-tests": "tsc --project tsconfig.json",
    "watch": "npm-run-all -p watch:esbuild watch:tsc",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && node esbuild.js --production",
    "check-types": "tsc --noEmit",
    "pretest": "npm run compile && npm run compile-tests && node -e \"require('fs').accessSync('out/test/suite/extension.test.js')\"",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.90.0",
    "@vscode/test-cli": "^0.0.9",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3",
    "esbuild": "^0.21",
    "mocha": "^10",
    "npm-run-all": "^4.1.5",
    "typescript": "~5.4"
  }
}
